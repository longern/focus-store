---
import SvgIcon from "@jamescoyle/vue-icon";
import { mdiArrowLeft } from "@mdi/js";

import ProductDetail from "@/components/ProductDetail";
import ProductDetailActions from "@/components/ProductDetailActions.vue";
import Layout from '@/layouts/NavBar.astro';
import { products } from "@/interfaces";

const product = products[0];
---

<Layout title="Product Detail">
  <header>
    <a href="/products">
      <button class="btn-icon">
        <SvgIcon type="mdi" path={mdiArrowLeft}></SvgIcon>
      </button>
    </a>
  </header>
  <main>
    <div class="container">
      <ProductDetail product={product}></ProductDetail>
    </div>
  </main>
  <ProductDetailActions client:only="vue" />
</Layout>

<style is:global>
  header {
    background-color: #333;
    color: white;
  }

  .container {
    margin: auto;
  }

  .product-detail {
    display: flex;
  }

  .product-detail .detail-text {
    margin: 8px;
  }

  .product-detail .price {
    font-size: 1.5em;
    margin: 8px;
  }

  @media not all and (max-width: 960px) {
    header {
      display: none;
    }

    .container {
      width: 1200px;
      padding: 12px;
    }

    .product-detail .detail-image {
      width: 400px;
    }
  }

  @media (max-width: 960px) {
    .product-detail {
      flex-direction: column;
    }

    .product-detail .detail-image {
      width: 100%;
    }
  }
</style>
