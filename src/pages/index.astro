---
import ProductCard from "@/components/ProductCard";
import { site } from "@/interfaces";
import Footer from "@/layouts/Footer.astro";
import Layout from "@/layouts/NavBar.astro";
---

<Layout preloads={[{href: site.coverImage, as: "image" }]}>
  <main class="home">
    <div class="cover-image" style={ `background-image: url("${site.coverImage}")` }>
      <div style="text-align: center">
        <div class="site-title">
          <h1>{site.title}</h1>
        </div>
        <a href="/products">
          <button class="btn-normal shop-now">
            <span>Shop Now</span>
          </button>
        </a>
      </div>
    </div>
    { site.aboutUs ?
    <div class="about-us">
      <h1>About Us</h1>
      { site.aboutUs.split("\n").map(line => (<p>{line}</p>)) }
    </div>
    : null }
    { site.testimonials ?
    <div class="testimonials">
      <h1>Testimonials</h1>
      <div class="testimonials-list">
        { site.testimonials.map(testimonial => (
        <div class="testimonial">
          <div class="testimonial-avatar">
            <img src={ testimonial.avatar } width="100" height="100" />
            <div class="testimonial-name">{ testimonial.name }</div>
            <div class="testimonial-caption">{ testimonial.caption }</div>
          </div>
          <div class="testimonial-text">
            <div class="testimonial-quote">{ testimonial.quote }</div>
          </div>
        </div>
        )) }
      </div>
      <div style="clear: both;"></div>
    </div>
    : null }
    <Footer></Footer>
  </main>
</Layout>

<style>
  nav {
    display: flex;
    background-color: white;
  }

  main {
    height: 100%;
    overflow-y: auto;
    scroll-snap-type: y mandatory;
  }

  .cover-image {
    position: relative;
    height: 100%;
    background-repeat: no-repeat;
    background-position: center center;
    background-size: cover;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .shop-now {
    display: inline-block;
    background-color: #444;
    color: white;
    font-size: 20px;
    padding: 12px 24px;
    border-radius: 4px;
  }

  .about-us,
  .testimonials {
    max-width: 800px;
    margin: auto;
    padding: 8px;
    text-align: center;
  }

  .testimonial-avatar {
    float: left;
    margin: 12px;
  }

  .testimonial-avatar>img {
    border-radius: 50%;
  }

  @media (max-width: 960px) {
    main>* {
      height: 100%;
      scroll-snap-align: center;
      box-sizing: border-box;
    }
  }
</style>
