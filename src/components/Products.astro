---
import ProductCard from "@/components/ProductCard";
import { Product } from '@/interfaces';

const { products } = Astro.props as { products: Array<Product> };
---

<div class="products">
  {products.map(product => (<ProductCard product={ product }></ProductCard>))}
</div>

<style is:global>
  .products {
    display: flex;
    margin: 4px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .products .product-card {
    width: 300px;
  }

  .products .product-card>a {
    margin: 4px;
    display: block;
    border-radius: 6px;
    background-color: white;
    overflow: hidden;
  }

  @media (max-width: 960px) {
    .products .product-card {
      flex-basis: 50%;
    }
  }

  .products .product-card .card-text {
    padding: 8px;
  }

  .products .product-card .price {
    font-size: 1.1em;
  }
</style>
